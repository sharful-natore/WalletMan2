# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# DRIVE_API: Google Sign-In and Google Drive REST API Web Client ID
DRIVE_API=YOUR_DRIVE_API_CLIENT_ID

# FIRESTORE SECRETS
Firestore_Project_ID=YOUR_FIRESTORE_PROJECT_ID
Firestore_APP_ID=YOUR_FIRESTORE_APP_ID
Firestore_Project_Number=YOUR_FIRESTORE_PROJECT_NUMBER

