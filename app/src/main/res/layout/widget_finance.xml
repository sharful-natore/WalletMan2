<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="4dp">

    <!-- Row 0: Profile Card -->
    <RelativeLayout
        android:id="@+id/card_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:layout_marginBottom="4dp"
        android:background="@drawable/widget_card_bg"
        android:padding="10dp"
        android:clickable="true"
        android:focusable="true">

        <!-- Avatar Container -->
        <RelativeLayout
            android:id="@+id/avatar_container"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_avatar_bg"
            android:gravity="center"
            android:layout_marginRight="10dp">
            
            <ImageView
                android:id="@+id/iv_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone" />
            
            <ImageView
                android:id="@+id/iv_default_logo"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_app_logo"
                android:tint="#FFFFFF"
                android:visibility="visible" />
            
            <TextView
                android:id="@+id/tv_avatar_initials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />
        </RelativeLayout>

        <!-- Welcome Text and Profile Details -->
        <LinearLayout
            android:id="@+id/profile_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@id/avatar_container"
            android:layout_toLeftOf="@id/clock_container"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:layout_marginRight="4dp">

            <TextView
                android:id="@+id/tv_welcome_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="স্বাগতম,"
                android:textColor="#CCFFFFFF"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_profile_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shariful Islam"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView
                    android:id="@+id/btn_widget_switch_workspace"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginLeft="4dp"
                    android:src="@drawable/ic_arrow_down"
                    android:tint="#FFFFFF"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>

        </LinearLayout>
        
        <!-- Gregorian, Bengali, and Arabic Dates -->
        <LinearLayout
            android:id="@+id/clock_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="vertical"
            android:gravity="right"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="8dp">
            
            <!-- Gregorian Date & Weekday -->
            <TextView
                android:id="@+id/tv_date_english"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monday, 13 July 2026"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9.5sp"
                android:maxLines="1"
                android:ellipsize="end" />
                
            <!-- Bengali Date -->
            <TextView
                android:id="@+id/tv_date_bengali"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="২৯ আষাঢ়, ১৪৩৩ বঙ্গাব্দ"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9.5sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />

            <!-- Arabic Date -->
            <TextView
                android:id="@+id/tv_date_arabic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="২৭ মহররম, ১৪৪৮ হিজরি"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9.5sp"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

    </RelativeLayout>

    <!-- Row 1: Summary Cards (Square-ish) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Income/Balance Card -->
        <RelativeLayout
            android:id="@+id/card_income"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/widget_card_bg"
            android:padding="10dp"
            android:clickable="true">
            <TextView
                android:id="@+id/lbl_income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="আয়"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />
            <TextView
                android:id="@+id/tv_income"
                android:layout_below="@id/lbl_income"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="৳ 0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_trending_up"
                android:alpha="0.6" />
        </RelativeLayout>

        <!-- Expense Card -->
        <RelativeLayout
            android:id="@+id/card_expense"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/widget_card_bg"
            android:padding="10dp"
            android:clickable="true">
            <TextView
                android:id="@+id/lbl_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ব্যয়"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />
            <TextView
                android:id="@+id/tv_expense"
                android:layout_below="@id/lbl_expense"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="৳ 0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_trending_down"
                android:alpha="0.6" />
        </RelativeLayout>

        <!-- Debt Card -->
        <RelativeLayout
            android:id="@+id/card_debt"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/widget_card_bg"
            android:padding="10dp"
            android:clickable="true">
            <TextView
                android:id="@+id/lbl_debt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="দেনা"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />
            <TextView
                android:id="@+id/tv_debt"
                android:layout_below="@id/lbl_debt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="৳ 0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_arrow_up"
                android:alpha="0.6" />
        </RelativeLayout>

        <!-- Credit Card -->
        <RelativeLayout
            android:id="@+id/card_credit"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/widget_card_bg"
            android:padding="10dp"
            android:clickable="true">
            <TextView
                android:id="@+id/lbl_credit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="পাওনা"
                android:textColor="#CCFFFFFF"
                android:textSize="10sp" />
            <TextView
                android:id="@+id/tv_credit"
                android:layout_below="@id/lbl_credit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="৳ 0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="9sp"
                android:maxLines="1"
                android:ellipsize="end" />
            <ImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_alignParentBottom="true"
                android:layout_alignParentRight="true"
                android:src="@drawable/ic_arrow_down"
                android:alpha="0.6" />
        </RelativeLayout>
    </LinearLayout>

    <!-- Row 2: Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:baselineAligned="false">

        <!-- Add Transaction Button -->
        <LinearLayout
            android:id="@+id/btn_add_tx"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_add"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Add Debt/Credit Button -->
        <LinearLayout
            android:id="@+id/btn_add_person"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_lend_borrow_new"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Add Saving Button -->
        <LinearLayout
            android:id="@+id/btn_add_saving"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_card"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Sync Button -->
        <LinearLayout
            android:id="@+id/btn_sync"
            android:layout_width="43dp"
            android:layout_height="43dp"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="21dp"
                android:layout_height="21dp"
                android:src="@drawable/ic_sync_24"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
