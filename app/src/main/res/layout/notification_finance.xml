<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_main_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:padding="12dp">

    <!-- Header Section (App Name and Live Status/Time) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="Sanchay (সঞ্চয়) - Finance Note"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="Active"
            android:textColor="#B0FFFFFF"
            android:textSize="11sp" />
    </RelativeLayout>

    <!-- Action Buttons Grid (Full Width & Equal Weight Spacing) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout android:id="@+id/btn_notif_dashboard"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/gradient_notif_button"
            android:gravity="center"
            android:clickable="true">
            <ImageView android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_dashboard"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_notif_tx"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/gradient_notif_button"
            android:gravity="center"
            android:clickable="true">
            <ImageView android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_add"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_notif_debt"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/gradient_notif_button"
            android:gravity="center"
            android:clickable="true">
            <ImageView android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_person_add"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_notif_savings"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/gradient_notif_button"
            android:gravity="center"
            android:clickable="true">
            <ImageView android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_card"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_notif_backup"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/gradient_notif_button"
            android:gravity="center"
            android:clickable="true">
            <ImageView android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_cloud_backup"
                android:tint="#FFFFFF" />
        </LinearLayout>

        <LinearLayout android:id="@+id/btn_notif_settings"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="3dp"
            android:background="@drawable/gradient_notif_button"
            android:gravity="center"
            android:clickable="true">
            <ImageView android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_settings"
                android:tint="#FFFFFF" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
